---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import '../styles/modern.css';

const title = "Engineering — Mark Stenquist";
const description = "15+ years building for the web. Case studies, technical writing, and projects from VisualBoston and beyond.";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero hero--full reveal">
				<div class="hero-text">
					<h1 class="text-display">Building for the web.</h1>
					<p class="text-lead">
						Co-founder and lead engineer at <a href="https://visualboston.com" target="_blank" class="link-enhanced">VisualBoston</a>. 15+ years shipping products across startups, agencies, and my own ventures. AI-first development is my current obsession.
					</p>
				</div>
			</section>

			<section class="section-card reveal-stagger">
				<h2 class="text-section-heading">Current Projects</h2>

				<div class="project-list">
					<div class="project-item">
						<div class="project-header">
							<h3>TallyQuote</h3>
							<a href="https://tallyquote.com" target="_blank" class="link-enhanced project-link">tallyquote.com →</a>
						</div>
						<p class="text-body">Voice-powered estimating for tradespeople. Record a job site walkthrough, AI extracts line items and generates a professional proposal in minutes.</p>
					</div>

					<div class="project-item">
						<div class="project-header">
							<h3>VisualBoston</h3>
							<a href="https://visualboston.com" target="_blank" class="link-enhanced project-link">visualboston.com →</a>
						</div>
						<p class="text-body">The agency I co-founded in 2020. We build digital products for ambitious companies — from early-stage startups to established brands.</p>
					</div>

					<div class="project-item">
						<div class="project-header">
							<h3>Garden Sharing App <span class="project-badge">Coming soon</span></h3>
						</div>
						<p class="text-body">A marketplace connecting people who want to grow food with neighbors who have the space for it. Think Airbnb for garden plots.</p>
					</div>
				</div>
			</section>

			<section class="section-card reveal-stagger">
				<h2 class="text-section-heading">Stack</h2>
				<p class="text-body">React, Next.js, TypeScript, Node.js, Astro, Tailwind, Postgres, Vercel. AI integrations with Claude, OpenAI, and whatever makes sense for the problem.</p>
			</section>

			<section class="section-card reveal-stagger">
				<h2 class="text-section-heading">Get In Touch</h2>
				<p class="text-body"><a href="mailto:mark@stenquist.com" class="link-enhanced">mark@stenquist.com</a></p>
			</section>
		</main>
		<Footer />
		<ScrollReveal />
	</body>
</html>

<style>
.project-list {
	display: flex;
	flex-direction: column;
	gap: var(--space-8);
	margin-top: var(--space-6);
}
.project-item {
	padding-bottom: var(--space-8);
	border-bottom: 1px solid var(--border-light);
}
.project-item:last-child {
	border-bottom: none;
	padding-bottom: 0;
}
.project-header {
	display: flex;
	align-items: baseline;
	justify-content: space-between;
	gap: var(--space-4);
	margin-bottom: var(--space-2);
	flex-wrap: wrap;
}
.project-header h3 {
	font-family: var(--font-mono);
	font-size: var(--text-lg);
	font-weight: 600;
	color: var(--text-primary);
}
.project-link {
	font-family: var(--font-mono);
	font-size: var(--text-sm);
}
.coming-soon-card {
	border: 1px dashed var(--border);
	background: var(--sand-50);
}
.project-badge {
	font-family: var(--font-mono);
	font-size: 0.68rem;
	font-weight: 600;
	background: var(--accent);
	color: #fff;
	padding: 0.2rem 0.6rem;
	border-radius: 99px;
	vertical-align: middle;
	margin-left: 0.5rem;
	letter-spacing: 0.03em;
}
</style>
