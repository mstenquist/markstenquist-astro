---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import '../styles/modern.css';
---

<style>
	/* Hero CTA */
	.hero-cta {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--surface);
		background: var(--accent);
		padding: 0.65rem 1.25rem;
		border-radius: var(--radius-md);
		text-decoration: none;
		transition: background 0.2s ease, transform 0.15s ease;
		margin-top: var(--space-2);
	}
	.hero-cta:hover {
		background: var(--accent-dark);
		transform: translateY(-1px);
	}
	.hero-cta:active {
		transform: translateY(0);
	}

	/* VisualBoston Feature */
	.vb-feature {
		display: block;
		text-decoration: none;
		background: #0e1117;
		border: 1px solid #1e2a38;
		border-radius: var(--radius-lg);
		margin-top: var(--space-12);
		margin-bottom: var(--space-8);
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.vb-feature:hover {
		border-color: #00c9a7;
		box-shadow: 0 0 0 1px #00c9a7, 0 8px 32px rgba(0,201,167,0.08);
	}
	.vb-feature-inner {
		padding: var(--space-8) var(--space-8);
	}
	.vb-label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #00c9a7;
		display: block;
		margin-bottom: var(--space-2);
	}
	.vb-name {
		font-family: var(--font-sans);
		font-size: 1.75rem;
		font-weight: 800;
		color: #f0f4f8;
		margin: 0 0 var(--space-4);
		letter-spacing: -0.025em;
	}
	.vb-desc {
		font-family: var(--font-sans);
		font-size: 0.95rem;
		color: #8899aa;
		line-height: 1.65;
		max-width: 520px;
		margin: 0 0 var(--space-6);
	}
	.vb-cta {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		font-weight: 600;
		color: #00c9a7;
	}

	/* Worlds Section */
	.worlds-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-6);
		margin-top: var(--space-6);
	}
	.worlds-intro {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		margin-bottom: 0;
	}
	.world-card {
		display: flex;
		flex-direction: column;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-8);
		box-shadow: var(--shadow-sm);
		transition: box-shadow 0.2s ease, border-color 0.2s ease;
		text-decoration: none;
		color: inherit;
	}
	.world-card:hover {
		box-shadow: var(--shadow-md);
		border-color: var(--accent);
	}
	.world-card-icon {
		display: block;
		font-size: 2rem;
		margin-bottom: var(--space-4);
	}
	.world-card-title {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: var(--text-xl);
		color: var(--text-primary);
		margin: 0 0 var(--space-1);
	}
	.world-card-tagline {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0 0 var(--space-4);
	}
	.world-card-desc {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		line-height: 1.6;
		margin: 0;
	}
	.world-card-cta {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent);
		font-weight: 600;
		margin-top: auto;
		padding-top: var(--space-4);
	}

	/* Timeline */
	.timeline {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin-top: var(--space-6);
		position: relative;
		padding-left: 5rem;
	}
	.timeline::before {
		content: '';
		position: absolute;
		left: 3.25rem;
		top: 0.5rem;
		bottom: 0.5rem;
		width: 1px;
		background: var(--border);
	}
	.timeline-item {
		position: relative;
		padding-bottom: var(--space-8);
		display: flex;
		align-items: flex-start;
	}
	.timeline-item:last-child { padding-bottom: 0; }
	.timeline-year {
		position: absolute;
		left: -4.75rem;
		top: 0.05rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		color: var(--accent);
		letter-spacing: 0.04em;
		white-space: nowrap;
	}
	.timeline-item::before {
		content: '';
		position: absolute;
		left: -1.6rem;
		top: 0.42rem;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--accent);
		border: 2px solid var(--background);
		box-shadow: 0 0 0 1px var(--accent);
	}
	.timeline-body h3 {
		font-family: var(--font-sans);
		font-size: var(--text-base);
		font-weight: 700;
		color: var(--text-primary);
		margin: 0 0 var(--space-1);
	}
	.timeline-body p {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		line-height: 1.65;
		margin: 0;
	}
	@media (max-width: 500px) {
		.timeline { padding-left: 4rem; }
		.timeline::before { left: 2.5rem; }
		.timeline-year { left: -3.9rem; font-size: 0.68rem; }
		.timeline-item::before { left: -1.55rem; }
	}

	/* Projects */
	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-6);
		margin-top: var(--space-6);
	}
	.project-card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-6);
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.project-card:hover {
		border-color: var(--accent);
		box-shadow: var(--shadow-md);
	}
	.project-header {
		display: flex;
		align-items: flex-start;
		gap: var(--space-4);
	}
	.project-icon { font-size: 1.75rem; line-height: 1; flex-shrink: 0; }
	.project-logo {
		height: 28px;
		width: auto;
	}
	.project-logo-dark { display: none; }
	@media (prefers-color-scheme: dark) {
		:root:not([data-theme="light"]) .project-logo-light { display: none; }
		:root:not([data-theme="light"]) .project-logo-dark { display: block; }
	}
	:global([data-theme="dark"]) .project-logo-light { display: none; }
	:global([data-theme="dark"]) .project-logo-dark { display: block; }
	.project-name {
		font-family: var(--font-sans);
		font-size: var(--text-lg);
		font-weight: 700;
		color: var(--text-primary);
		margin: 0 0 var(--space-1);
	}
	.project-tagline {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0;
	}
	.project-desc {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		line-height: 1.65;
		margin: 0;
		flex: 1;
	}
	.project-stack {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
	}
	.stack-badge {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 500;
		color: var(--text-secondary);
		background: var(--background);
		border: 1px solid var(--border);
		padding: 0.2rem 0.55rem;
		border-radius: var(--radius-sm);
	}

	/* Contact Section */
	.contact-grid {
		display: flex;
		gap: var(--space-6);
		margin-top: var(--space-6);
		flex-wrap: wrap;
	}
	.contact-link {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--accent);
		text-decoration: none;
		padding: 0.5rem 1rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		transition: border-color 0.2s ease, background 0.2s ease;
	}
	.contact-link:hover {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 8%, transparent);
	}
</style>

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero reveal">
				<div class="profile-image">
					<img src="/images/mark-feature-photo.jpg" alt="Mark Stenquist, frontend engineer based in Westwood, MA" />
				</div>
				<div class="hero-text">
					<h1 class="text-display">Hi, I'm Mark.</h1>
					<p class="text-lead">Running a web agency, building my own products, and growing food in suburban Boston.</p>
					<a href="/engineering" class="hero-cta">See my work &rarr;</a>
				</div>
			</section>

			<section class="section-card reveal-stagger">
				<h2 class="text-section-heading">About</h2>
				<p class="text-body">
					I got my start on the founding team of <a href="https://techcrunch.com/2011/04/25/campuslive-raises-3-1-million-to-help-brands-connect-with-college-students/" target="_blank" class="link-enhanced">CampusLIVE</a> at UMass, a dorm room startup that grew into a multi-million dollar company backed by Highland Capital Partners and CRV. From there I joined Google Ventures-backed <a href="https://venturebeat.com/entrepreneur/custom-goods-marketplace-custommade-cooks-up-18m-from-google-atlas-others/" target="_blank" class="link-enhanced">CustomMade</a>, where I built frontend systems connecting thousands of artisans with customers seeking custom goods.
				</p>
				<p class="text-body">
					After that I spent five years as an independent consultant, working with Boston-area startups across fintech, healthcare, and beyond. In 2020 I co-founded <a href="https://visualboston.com" target="_blank" class="link-enhanced">VisualBoston</a>, where I lead engineering. My current focus is AI-first development, building tools and workflows that fundamentally change how digital products get made.
				</p>
			</section>

			<a href="https://visualboston.com" target="_blank" rel="noopener noreferrer" class="vb-feature reveal-stagger">
				<div class="vb-feature-inner">
					<div class="vb-feature-text">
						<span class="vb-label">Co-founder & Lead Engineer</span>
						<h2 class="vb-name">VisualBoston</h2>
						<p class="vb-desc">We design and build websites, apps, and AI-powered tools for ambitious companies. Senior talent, no overhead, available when you need us.</p>
						<span class="vb-cta">visualboston.com &rarr;</span>
					</div>
				</div>
			</a>

			<section class="section-card reveal-stagger">
				<h2 class="text-section-heading">Timeline</h2>
				<div class="timeline">
					<div class="timeline-item">
						<span class="timeline-year">2011</span>
						<div class="timeline-body">
							<h3>CampusLIVE</h3>
							<p>Joined the founding team at UMass. Grew from a dorm-room idea into a multi-million dollar company backed by Highland Capital Partners and CRV.</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-year">2013</span>
						<div class="timeline-body">
							<h3>CustomMade</h3>
							<p>Built frontend systems at Google Ventures-backed CustomMade, connecting thousands of artisans with customers seeking custom goods.</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-year">2015</span>
						<div class="timeline-body">
							<h3>Independent Consulting</h3>
							<p>Five years working with Boston-area startups across fintech, healthcare, and consumer products as a freelance engineer and technical lead.</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-year">2020</span>
						<div class="timeline-body">
							<h3>Co-founded VisualBoston</h3>
							<p>Launched a boutique engineering and design agency with a focus on ambitious digital products and AI-first development.</p>
						</div>
					</div>
					<div class="timeline-item">
						<span class="timeline-year">2025</span>
						<div class="timeline-body">
							<h3>Building with AI</h3>
							<p>Shipping TallyQuote (proposal-to-booking for contractors) and GardenMates (land-sharing marketplace for gardeners) , both AI-native from day one.</p>
						</div>
					</div>
				</div>
			</section>

			<section class="section-card reveal-stagger">
				<h2 class="text-section-heading">Projects</h2>
				<div class="projects-grid">
					<a href="https://tallyquote.com" target="_blank" rel="noopener noreferrer" class="project-card">
						<div class="project-header">
							<img src="/images/tallyquote-logo-light.svg" alt="TallyQuote" class="project-logo project-logo-light" />
							<img src="/images/tallyquote-logo.svg" alt="TallyQuote" class="project-logo project-logo-dark" />
						</div>
						<p class="project-desc">A proposal-to-booking platform for contractors. The client describes what they need, AI drafts a proposal, the contractor tweaks and sends it, and the client can sign and schedule, all in one flow.</p>
						<div class="project-stack">
							<span class="stack-badge">Next.js</span>
							<span class="stack-badge">TypeScript</span>
							<span class="stack-badge">Claude API</span>
							<span class="stack-badge">Stripe</span>
						</div>
					</a>
					<div class="project-card">
						<div class="project-header">
							<span class="project-icon">🌱</span>
							<div>
								<h3 class="project-name">GardenMates</h3>
								<p class="project-tagline">Land-sharing for gardeners</p>
							</div>
						</div>
						<p class="project-desc">Connects people who want to grow food with neighbors who have unused outdoor space. Landowners get a cut of the harvest or a monthly fee. Gardeners get a plot without needing a yard.</p>
						<div class="project-stack">
							<span class="stack-badge">React</span>
							<span class="stack-badge">TypeScript</span>
							<span class="stack-badge">Prisma</span>
							<span class="stack-badge">Neon</span>
						</div>
					</div>
				</div>
			</section>

			<section class="section-card reveal-stagger">
				<h2 class="text-section-heading">Interests</h2>
				<p class="worlds-intro">A few things I spend serious time on. Each has its own space to go deeper.</p>
				<div class="worlds-grid">
					<a class="world-card" href="/engineering">
						<span class="world-card-icon">💻</span>
						<h3 class="world-card-title">Engineering</h3>
						<p class="world-card-tagline">Web development & AI</p>
						<p class="world-card-desc">Case studies, current projects, and technical writing.</p>
						<span class="world-card-cta">Explore &rarr;</span>
					</a>
					<a class="world-card" href="https://gardening.markstenquist.com" target="_blank" rel="noopener noreferrer">
						<span class="world-card-icon">🌿</span>
						<h3 class="world-card-title">Gardening</h3>
						<p class="world-card-tagline">Permaculture & backyard growing</p>
						<p class="world-card-desc">Season notes, garden experiments, and consultation.</p>
						<span class="world-card-cta">Explore &rarr;</span>
					</a>
				</div>
			</section>

			<section class="section-card reveal-stagger">
				<h2 class="text-section-heading">Get In Touch</h2>
				<p class="text-body">Open to consulting engagements, collaboration on interesting projects, or just a conversation about building things.</p>
				<div class="contact-grid">
					<a href="mailto:mark@stenquist.com" class="contact-link">mark@stenquist.com</a>
					<a href="https://linkedin.com/in/markstenquist" target="_blank" rel="noopener noreferrer" class="contact-link">LinkedIn</a>
					<a href="https://github.com/mstenquist" target="_blank" rel="noopener noreferrer" class="contact-link">GitHub</a>
				</div>
			</section>
		</main>
		<Footer />
		<ScrollReveal />
	</body>
</html>
