---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import '../styles/modern.css';
---

<style>
	/* Worlds Section */
	.worlds-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: var(--space-6);
		margin-top: var(--space-6);
	}
	.worlds-intro {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		margin-bottom: 0;
	}
	.world-card {
		display: flex;
		flex-direction: column;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: var(--space-8);
		box-shadow: var(--shadow-sm);
		transition: box-shadow 0.2s ease, border-color 0.2s ease;
		text-decoration: none;
		color: inherit;
	}
	.world-card:hover {
		box-shadow: var(--shadow-md);
		border-color: var(--accent);
	}
	.world-card-icon {
		display: block;
		font-size: 2rem;
		margin-bottom: var(--space-4);
	}
	.world-card-title {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: var(--text-xl);
		color: var(--text-primary);
		margin: 0 0 var(--space-1);
	}
	.world-card-tagline {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0 0 var(--space-4);
	}
	.world-card-desc {
		font-family: var(--font-sans);
		font-size: var(--text-sm);
		color: var(--text-secondary);
		line-height: 1.6;
		margin: 0;
	}
	.world-card-cta {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent);
		font-weight: 600;
		margin-top: auto;
		padding-top: var(--space-4);
	}
</style>

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero reveal">
				<div class="profile-image">
					<img src="/images/mark-feature-photo.jpg" alt="Mark Stenquist" />
				</div>
				<div class="hero-text">
					<h1 class="text-display">Hi, I'm Mark.</h1>
					<p class="text-lead">Engineer. Gardener. Dad.<br />Based in suburban Boston.</p>
					<p class="text-body">
						I build things on the web and grow things in the backyard. Co-founder of <a href="https://visualboston.com" target="_blank" class="link-enhanced">VisualBoston</a>. Permaculture nerd.
					</p>
				</div>
			</section>

			<section class="section-card reveal-stagger">
				<h2 class="text-section-heading">Interests</h2>
				<p class="worlds-intro">A few things I spend serious time on. Each has its own space to go deeper.</p>
				<div class="worlds-grid">
					<a class="world-card" href="/engineering">
						<span class="world-card-icon">💻</span>
						<h3 class="world-card-title">Engineering</h3>
						<p class="world-card-tagline">Web development & AI</p>
						<p class="world-card-desc">Case studies, current projects, and technical writing.</p>
						<span class="world-card-cta">Explore →</span>
					</a>
					<a class="world-card" href="https://gardening.markstenquist.com" target="_blank" rel="noopener noreferrer">
						<span class="world-card-icon">🌿</span>
						<h3 class="world-card-title">Gardening</h3>
						<p class="world-card-tagline">Permaculture & backyard growing</p>
						<p class="world-card-desc">Season notes, garden experiments, and consultation.</p>
						<span class="world-card-cta">Explore →</span>
					</a>
				</div>
			</section>
		</main>
		<Footer />
		<ScrollReveal />
	</body>
</html>
